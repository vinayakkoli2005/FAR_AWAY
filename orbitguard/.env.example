# Optional — everything works without these.

# Groq free tier (llama-3.3-70b-versatile) for LLM narration of evidence
# records. Without a key, the deterministic template renderer is used.
GROQ_API_KEY=

# Space-Track.org credentials for public CDM ingest (stretch goal).
SPACETRACK_USER=
SPACETRACK_PASSWORD=

# Default demo assets (NORAD IDs): ISS, Pixxel FIREFLY-1, GalaxEye DRISHTI, ISRO EOS-08
ORBITGUARD_ASSETS=25544,62701,69010,60454

# Frontend -> API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000
